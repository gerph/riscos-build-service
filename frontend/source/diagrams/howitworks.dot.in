# How it works

//#include "flowchart.dot.pp"

//#define SHOW_JSON_SERVER

#define TITLE JFPatch as a Service: Structural diagram

#define ICON(x) icons/##x.png
#define LABEL_ICON(icon, text) <<TABLE border="0" cellspacing="0" cellborder="0"><TR><TD width="24" height="24" fixedsize="TRUE"><IMG SCALE="BOTH" SRC=STRINGIFY(ICON(icon))/></TD><TD>text</TD><TD></TD></TR></TABLE>>

#define VALUE(x) #x
#define STRINGIFY(x) VALUE(x)


digraph STRINGIFY(TITLE) {
#include "chartconfig.dot.pp"

    // Force the clusters to be more compact
    newrank = true;

    node [ style=filled; fillcolor=white; ];

    // ---- Components of the system ----
    User [ label="User through browser" ];
    UserTool [ label="User through tool" ];
    CloudFront [ label=LABEL_ICON(cloudfront, AWS CloudFront<BR/>CDN and routing) ];
    WSServer [ label=LABEL_ICON(python, Back end server<BR/>Web sockets server) ];
#ifdef SHOW_JSON_SERVER
    JSONServer [label=LABEL_ICON(python, Back end serevr<BR/>JSON server) ];
#endif
    FrontEndSite [ label=LABEL_ICON(apache, Front end site<BR/>Static site content) ];
    WSInternalServer [ label=LABEL_ICON(python, Internal server<BR/>HTTP for callback from RISC OS) ];
    Docker [ label=LABEL_ICON(docker, Docker container) ];
    Pyromaniac [ label=LABEL_ICON(cog, RISC OS) ];
    JFPatch [ label=LABEL_ICON(plaster, Build tool<BR/>JFPatch command line tool) ];

    {
        rank=same;
        Docker;
        WSInternalServer;
    }

    // ---- Groupings (Things that contain things) ----
    subgraph cluster_awsserver {
        graph [
            bgcolor="#FCDDB4"; // That's the AWS EC2 orange #F7981F + 75% alpha to white
            color=black;

            label = LABEL_ICON(ec2, EC2 server);
            labelloc = "b";
            labeljust = "l"
        ];
        WSServer;
#ifdef SHOW_JSON_SERVER
        JSONServer;
#endif
        WSInternalServer;

        subgraph cluster_docker {
            graph [
                bgcolor="#B6DCF9"; // That's the docker blue #2496ed + 75% alpha to white
                color=black;

                label = "";
                labelloc = "b";
            ];

            Docker;
            subgraph cluster_pyromaniac {
                bgcolor="palegreen"; // same as the JFPatch top bar
                color=black;

                Pyromaniac;
                JFPatch;
            }
        }
    }

    User -> CloudFront;
    UserTool -> CloudFront;
    CloudFront -> FrontEndSite;
    CloudFront -> WSServer;
#ifdef SHOW_JSON_SERVER
    CloudFront -> JSONServer;
#endif

    WSServer -> Docker;
#ifdef SHOW_JSON_SERVER
    JSONServer -> Docker;
#endif
    Docker -> Pyromaniac;
    Pyromaniac -> JFPatch;
    WSInternalServer -> WSServer [ constraint=false ];
#ifdef SHOW_JSON_SERVER
    WSInternalServer -> JSONServer [ constraint=false ];
#endif
    JFPatch -> WSInternalServer [ tailport=s, label="Clipboard data transfer\nand Throwback events", labeldistance=1, labelangle=-40 ];
}
