%YAML 1.1
---
# Configuration for use with JFPatch

config:
  safe: true

  emulation.disable_interrupt: yes
  graphics.implementation: 'null'
  memorymap.zeropage_enable: yes
  memorymap.appspace_size: 12M
  input.readline_native: yes
  taskwindow.in_taskwindow: true
  filesystem.native_directory: fs
  input.eof_effect: exit
  vdu.implementation: ansitext
  VDUANSIText.support_primarybold: no

variables:
  'JFPatch$ScrapDir': '$.tmp'
  'JFPatch$Dir': '$.Library.JFPatchResources'
