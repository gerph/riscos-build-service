In   -
Out  test
Type AOF Debug
Ver  1.00m

#Area "Main" Code ReadOnly
#Rem On
#CodePrefix =Prefix
>|main|
   STMFD   (sp)!,{r0-r5,link}            ; Stack registers
   REM     "Main called - returning..."
   ADR     r0,$`string1
   ADR     r1,$`string2
   MOV     r2,#3
   BL      |strncmp|
   REM     "strncmp returned %r0"
   LDMFD   (sp)!,{r0-r5,pc}              ; Return from call
   EQUD    |__main|

$`string1
   EQUZA   "justin"
$`string2
   EQUZA   "ju1tine"
